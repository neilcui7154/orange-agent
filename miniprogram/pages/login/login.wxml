<!--miniprogram/pages/login/login.wxml-->
<view class="container">
  <view class="logo-section">
    <image class="logo" src="/images/logo.png" mode="aspectFit"></image>
    <text class="title">橙司保贝</text>
    <text class="subtitle">AI 赋能，展业无忧</text>
  </view>

  <view class="form-section">
    <view class="input-group">
      <text class="label">手机号</text>
      <input
        class="input"
        type="number"
        placeholder="请输入手机号"
        value="{{phone}}"
        bindinput="onPhoneInput"
        maxlength="11"
      />
    </view>

    <view class="input-group">
      <text class="label">邀请码</text>
      <input
        class="input"
        type="text"
        placeholder="请输入邀请码"
        value="{{inviteCode}}"
        bindinput="onInviteCodeInput"
      />
    </view>

    <button
      class="login-btn"
      bindtap="onLogin"
      disabled="{{!phone || !inviteCode || isLoading}}"
    >
      {{isLoading ? '登录中...' : '登录'}}
    </button>

    <view class="tips">
      <text class="tip-text">· 仅限团队内部使用</text>
    </view>
  </view>

  <view class="footer">
    <text class="footer-text">个人娱乐 · 概不负责</text>
  </view>
</view>
